{
  "name": "polkadot-cli",
  "version": "1.22.0",
  "description": "CLI tool for querying Polkadot-ecosystem on-chain state",
  "type": "module",
  "bin": {
    "dot": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "bun build src/cli.ts --outfile dist/cli.mjs --target node --packages external && bun run build:shebang",
    "build:shebang": "bun -e \"const f='dist/cli.mjs'; const s=await Bun.file(f).text(); await Bun.write(f, s.replace('#!/usr/bin/env bun', '#!/usr/bin/env node').replace('// @bun\\n',''))\"",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun test --concurrent",
    "test:coverage": "bun test --concurrent --coverage --coverage-reporter=lcov --coverage-dir=coverage",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "license": "MIT",
  "keywords": [
    "polkadot",
    "substrate",
    "blockchain",
    "cli",
    "web3"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paritytech/polkadot-cli.git"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@polkadot-api/metadata-builders": "^0.14.3",
    "@polkadot-api/substrate-bindings": "^0.20.3",
    "@polkadot-api/substrate-client": "^0.7.0",
    "@polkadot-api/view-builder": "^0.5.3",
    "@polkadot-labs/hdkd": "^0.0.28",
    "@polkadot-labs/hdkd-helpers": "^0.0.30",
    "@scure/sr25519": "^1.0.0",
    "cac": "^7.0.0",
    "polkadot-api": "^2.1.7",
    "verifiablejs": "1.4.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@changesets/cli": "^2.31.0",
    "@polkadot-api/metadata-compatibility": "^0.6.3",
    "@types/bun": "^1.3.14",
    "husky": "^9.1.7"
  },
  "overrides": {
    "ws": ">=8.21.0"
  }
}
